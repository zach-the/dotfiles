#!/usr/bin/env python3
import sys
import os
import io
import subprocess
import difflib
import shutil
import re
import fnmatch
import fcntl
import signal
import selectors

RESET = '\033[0m'
RED = '\033[31m'
GREEN = '\033[32m'
BLUE = '\033[34m'
PURPLE = '\033[35m'
DIM = '\033[2m'
BOLD = '\033[1m'
CYAN = '\033[36m'
MATCH_BG = '\033[105m'
CUR_MATCH_BG = '\033[104m'
DARK_FG = '\033[30m'
FG_OFF = '\033[39m'
BG_OFF = '\033[49m'

# Add your regex patterns here to ignore specific files/directories
# e.g., r'\.git/.*', r'.*\.pyc'
EXCLUDE_PATTERNS = [
    r'.*\.git/.*',
    r'.*\.pyc',
    r'.*def',
    r'.*log',
    r'.*rpt',
    # r'.*\.shadow.*',
    r'.*csv',
    r'.*eco.\.tcl',
]

compiled_excludes = []
for p in EXCLUDE_PATTERNS:
    try:
        compiled_excludes.append(re.compile(p))
    except re.error:
        compiled_excludes.append(re.compile(fnmatch.translate(p)))

_ANSI_ESC = re.compile(r'\033\[[^a-zA-Z]*[a-zA-Z]')
_SGR = re.compile(r'\033\[([0-9;]*)m')

def _visible_len(s):
    return len(_ANSI_ESC.sub('', s))

def _ljust_visible(s, width):
    pad = width - _visible_len(s)
    return s + ' ' * pad if pad > 0 else s

def _wrap_ansi(line, width):
    """Wrap line at `width` visible characters, carrying active SGR color state to each chunk."""
    chunks, active, chunk, visible = [], [], "", 0
    i = 0
    while i < len(line):
        m = _ANSI_ESC.match(line, i)
        if m:
            seq = m.group()
            chunk += seq
            i = m.end()
            sgr = _SGR.fullmatch(seq)
            if sgr:
                if sgr.group(1) in ('', '0'):
                    active = []
                else:
                    active.append(seq)
        else:
            chunk += line[i]
            visible += 1
            i += 1
            if visible >= width:
                chunks.append(chunk)
                chunk = ''.join(active)
                visible = 0
    if chunk and visible > 0:
        chunks.append(chunk)
    return chunks if chunks else [""]

def _strip_ansi(s):
    return _ANSI_ESC.sub('', s)

def _highlight_line(line, spans):
    """Overlay `spans` (list of (start, end, is_current) into the line's stripped text) as a
    background-only highlight, leaving the line's own foreground (red/green diff color, or
    default) untouched. Falls back to a dark foreground only where no foreground is active,
    so the highlight stays readable over unstyled text without clobbering diff coloring."""
    if not spans:
        return line
    spans = sorted(spans, key=lambda x: x[0])
    out = []
    visible = 0
    i = 0
    sidx = 0
    fg_active = False
    cur_key = None
    forced_fg = False

    def open_span(is_current):
        nonlocal forced_fg
        out.append(CUR_MATCH_BG if is_current else MATCH_BG)
        forced_fg = not fg_active
        if forced_fg:
            out.append(DARK_FG)

    def close_span():
        nonlocal forced_fg
        out.append(BG_OFF)
        if forced_fg:
            out.append(FG_OFF)
        forced_fg = False

    while i < len(line):
        m = _ANSI_ESC.match(line, i)
        if m:
            seq = m.group()
            out.append(seq)
            sgr = _SGR.fullmatch(seq)
            if sgr:
                for p in sgr.group(1).split(';'):
                    code = int(p) if p else 0
                    if code in (0, 39):
                        fg_active = False
                    elif 30 <= code <= 37 or 90 <= code <= 97:
                        fg_active = True
                if sgr.group(1) in ('', '0') and cur_key is not None:
                    open_span(cur_key)
            i = m.end()
            continue
        while sidx < len(spans) and visible >= spans[sidx][1]:
            sidx += 1
        hit = sidx < len(spans) and spans[sidx][0] <= visible < spans[sidx][1]
        new_key = spans[sidx][2] if hit else None
        if new_key != cur_key:
            if cur_key is not None:
                close_span()
            if new_key is not None:
                open_span(new_key)
            cur_key = new_key
        out.append(line[i])
        visible += 1
        i += 1
    if cur_key is not None:
        close_span()
    return ''.join(out)

def get_terminal_size():
    try:
        import struct, termios as _t
        h, w, _, _ = struct.unpack('HHHH',
            fcntl.ioctl(sys.stdout.fileno(), _t.TIOCGWINSZ,
            struct.pack('HHHH', 0, 0, 0, 0)))
        if w > 0 and h > 0:
            return w, h
    except Exception:
        pass
    try:
        s = shutil.get_terminal_size((80, 24))
        return s.columns, s.lines
    except Exception:
        pass
    return 80, 24

def get_terminal_width():
    if not sys.stdout.isatty():
        return 120
    return get_terminal_size()[0]

def build_ansi_string(char_color_list, width):
    out = []
    current_color = ''
    visual_len = 0
    for ch, color in char_color_list:
        if visual_len >= width:
            break
        if color != current_color:
            out.append(RESET if not color else color)
            current_color = color
        out.append(ch)
        visual_len += 1
    if current_color != '':
        out.append(RESET)
    if visual_len < width:
        out.append(' ' * (width - visual_len))
    return "".join(out)

def get_inline_diff(old_line, new_line):
    if old_line is None and new_line is None:
        return [], []
    if old_line is None:
        return [], [(ch, GREEN) for ch in new_line]
    if new_line is None:
        return [(ch, RED) for ch in old_line], []

    old_char_color = []
    new_char_color = []
    sm = difflib.SequenceMatcher(None, old_line, new_line)
    for ctag, i1, i2, j1, j2 in sm.get_opcodes():
        if ctag == 'equal':
            old_char_color.extend((old_line[i], '') for i in range(i1, i2))
            new_char_color.extend((new_line[j], '') for j in range(j1, j2))
        elif ctag == 'delete':
            old_char_color.extend((old_line[i], RED) for i in range(i1, i2))
        elif ctag == 'insert':
            new_char_color.extend((new_line[j], GREEN) for j in range(j1, j2))
        elif ctag == 'replace':
            old_char_color.extend((old_line[i], RED) for i in range(i1, i2))
            new_char_color.extend((new_line[j], GREEN) for j in range(j1, j2))
    return old_char_color, new_char_color

def process_diff(iterable, out, ignore_ws=False, term_width=None):
    if term_width is None:
        term_width = get_terminal_width()
    mid_sep = " | "
    left_width = (term_width - len(mid_sep)) // 2
    right_width = term_width - len(mid_sep) - left_width

    old_block = []
    new_block = []
    skip_current_file = False

    def flush_blocks():
        if skip_current_file:
            old_block.clear()
            new_block.clear()
            return
        if not old_block and not new_block:
            return

        old_lines = [line[1:] for line in old_block]
        new_lines = [line[1:] for line in new_block]

        sm = difflib.SequenceMatcher(None, old_lines, new_lines)
        aligned_old = []
        aligned_new = []
        for ctag, i1, i2, j1, j2 in sm.get_opcodes():
            if ctag == 'equal':
                for i, j in zip(range(i1, i2), range(j1, j2)):
                    aligned_old.append(old_lines[i])
                    aligned_new.append(new_lines[j])
            elif ctag == 'replace':
                chunk_old = old_lines[i1:i2]
                chunk_new = new_lines[j1:j2]
                max_len = max(len(chunk_old), len(chunk_new))
                for k in range(max_len):
                    o = chunk_old[k] if k < len(chunk_old) else None
                    n = chunk_new[k] if k < len(chunk_new) else None
                    aligned_old.append(o)
                    aligned_new.append(n)
            elif ctag == 'delete':
                for i in range(i1, i2):
                    aligned_old.append(old_lines[i])
                    aligned_new.append(None)
            elif ctag == 'insert':
                for j in range(j1, j2):
                    aligned_old.append(None)
                    aligned_new.append(new_lines[j])

        for o, n in zip(aligned_old, aligned_new):
            o_colors, n_colors = get_inline_diff(o, n)
            left_str = build_ansi_string(o_colors, left_width)
            right_str = build_ansi_string(n_colors, right_width)
            out.write(f"{left_str}{DIM}{mid_sep}{RESET}{right_str}\n")

        old_block.clear()
        new_block.clear()

    for line in iterable:
        line = line.rstrip('\r\n').expandtabs(4)
        if line.startswith('---') or line.startswith('+++') or line.startswith('index '):
            pass
        elif line.startswith('diff '):
            flush_blocks()
            parts = line.split()
            if len(parts) >= 3:
                f1 = parts[-2]
                f2 = parts[-1]
                skip_current_file = any(p.search(f1) or p.search(f2) for p in compiled_excludes)
                if skip_current_file:
                    continue
                out.write(f"\n{BLUE}{BOLD}FILE: {f1} <-> {f2}{RESET}\n")
            else:
                skip_current_file = False
                out.write(f"\n{BLUE}{BOLD}{line}{RESET}\n")
        elif skip_current_file:
            continue
        elif line.startswith('@@ '):
            flush_blocks()
            parts = line.split('@@')
            if len(parts) >= 3:
                nums = parts[1].strip().split()
                if len(nums) == 2:
                    old_nums = nums[0][1:]
                    new_nums = nums[1][1:]
                    old_start = old_nums.split(',')[0]
                    new_start = new_nums.split(',')[0]
                    out.write(f"{PURPLE}{BOLD}Lines {old_start} (left) / {new_start} (right):{RESET}\n")
                else:
                    out.write(f"{PURPLE}{line}{RESET}\n")
            else:
                out.write(f"{PURPLE}{line}{RESET}\n")
        elif line.startswith('-'):
            old_block.append(line)
        elif line.startswith('+'):
            new_block.append(line)
        elif line.startswith(' '):
            flush_blocks()
            content = line[1:]
            c_colors = [(ch, '') for ch in content]
            left_str = build_ansi_string(c_colors, left_width)
            right_str = build_ansi_string(c_colors, right_width)
            out.write(f"{left_str}{DIM}{mid_sep}{RESET}{right_str}\n")
        elif line.startswith('\\'):
            flush_blocks()
            out.write(f"{DIM}{line}{RESET}\n")
        else:
            flush_blocks()
            out.write(f"{line}\n")

    flush_blocks()

def generate_full_diff(file1, file2, ignore_ws=False, out=None, term_width=None):
    """Full side-by-side view of both files with line numbers and inline diff highlighting."""
    if out is None:
        out = sys.stdout
    if term_width is None:
        term_width = get_terminal_width()

    with open(file1) as f:
        lines1 = [l.rstrip('\n').expandtabs(4) for l in f]
    with open(file2) as f:
        lines2 = [l.rstrip('\n').expandtabs(4) for l in f]
    ln_width = max(len(str(len(lines1))), len(str(len(lines2))), 3)
    mid_sep = " | "
    ln_sep = " "
    # Layout: {lnum}{ln_sep}{left}{mid_sep}{right}{ln_sep}{rnum}
    overhead = (ln_width + len(ln_sep)) * 2 + len(mid_sep)
    content_total = max(10, term_width - overhead)
    left_width = content_total // 2
    right_width = content_total - left_width

    def norm(s):
        return re.sub(r'\s+', ' ', s.strip()) if ignore_ws else s

    cmp1 = [norm(l) for l in lines1]
    cmp2 = [norm(l) for l in lines2]
    sm = difflib.SequenceMatcher(None, cmp1, cmp2)

    has_diff = False
    ln1 = 0
    ln2 = 0

    out.write(f"\n{BLUE}{BOLD}FILE: {file1} <-> {file2}{RESET}\n")

    for ctag, i1, i2, j1, j2 in sm.get_opcodes():
        if ctag == 'equal':
            for i, j in zip(range(i1, i2), range(j1, j2)):
                ln1 += 1
                ln2 += 1
                c_colors = [(ch, '') for ch in lines1[i]]
                left_str = build_ansi_string(c_colors, left_width)
                right_str = build_ansi_string(c_colors, right_width)
                lnum = f"{DIM}{ln1:{ln_width}}{ln_sep}{RESET}"
                rnum = f"{DIM}{ln_sep}{ln2:{ln_width}}{RESET}"
                out.write(f"{lnum}{left_str}{DIM}{mid_sep}{RESET}{right_str}{rnum}\n")
        elif ctag == 'replace':
            has_diff = True
            chunk1 = lines1[i1:i2]
            chunk2 = lines2[j1:j2]
            max_len = max(len(chunk1), len(chunk2))
            for k in range(max_len):
                o = chunk1[k] if k < len(chunk1) else None
                n = chunk2[k] if k < len(chunk2) else None
                if o is not None:
                    ln1 += 1
                if n is not None:
                    ln2 += 1
                o_colors, n_colors = get_inline_diff(o, n)
                left_str = build_ansi_string(o_colors, left_width)
                right_str = build_ansi_string(n_colors, right_width)
                lnum = f"{DIM}{ln1:{ln_width}}{ln_sep}{RESET}" if o is not None else ' ' * (ln_width + len(ln_sep))
                rnum = f"{DIM}{ln_sep}{ln2:{ln_width}}{RESET}" if n is not None else ' ' * (ln_width + len(ln_sep))
                out.write(f"{lnum}{left_str}{DIM}{mid_sep}{RESET}{right_str}{rnum}\n")
        elif ctag == 'delete':
            has_diff = True
            for i in range(i1, i2):
                ln1 += 1
                o_colors, _ = get_inline_diff(lines1[i], None)
                left_str = build_ansi_string(o_colors, left_width)
                right_str = build_ansi_string([], right_width)
                lnum = f"{DIM}{ln1:{ln_width}}{ln_sep}{RESET}"
                rnum = ' ' * (ln_width + len(ln_sep))
                out.write(f"{lnum}{left_str}{DIM}{mid_sep}{RESET}{right_str}{rnum}\n")
        elif ctag == 'insert':
            has_diff = True
            for j in range(j1, j2):
                ln2 += 1
                _, n_colors = get_inline_diff(None, lines2[j])
                left_str = build_ansi_string([], left_width)
                right_str = build_ansi_string(n_colors, right_width)
                lnum = ' ' * (ln_width + len(ln_sep))
                rnum = f"{DIM}{ln_sep}{ln2:{ln_width}}{RESET}"
                out.write(f"{lnum}{left_str}{DIM}{mid_sep}{RESET}{right_str}{rnum}\n")

    return has_diff

def read_key(fd):
    """Read a key or escape sequence from fd; returns bytes."""
    c = os.read(fd, 1)
    if c == b'\x1b':
        flags = fcntl.fcntl(fd, fcntl.F_GETFL)
        fcntl.fcntl(fd, fcntl.F_SETFL, flags | os.O_NONBLOCK)
        try:
            c += os.read(fd, 16)
        except (BlockingIOError, OSError):
            pass
        finally:
            fcntl.fcntl(fd, fcntl.F_SETFL, flags)
    return c

def run_viewer(raw_lines, title="zd", regenerate=None):
    """Display rendered lines in an interactive TUI pager with vim/less keybindings."""
    try:
        tty_file = open('/dev/tty', 'rb')
        tty_fd = tty_file.fileno()
    except Exception:
        tty_file = None
        tty_fd = sys.stdin.fileno()

    import termios, tty as tty_mod
    old_termios = termios.tcgetattr(tty_fd)

    width, height = get_terminal_size()
    content_h = height - 1

    def make_wrapped(w):
        result = []
        for line in raw_lines:
            for chunk in _wrap_ansi(line, w):
                result.append(chunk)
        return result

    wrapped = make_wrapped(width)
    total = len(wrapped)
    top = 0
    needs_redraw = True
    running = True

    search_pattern = None
    search_dir = 1
    all_matches = []       # [(line_idx, start, end), ...] sorted by line_idx
    matches_by_line = {}   # line_idx -> [(start, end, global_index), ...]
    match_pos = -1         # index into all_matches of the currently selected match

    def compute_matches(pattern):
        matches = []
        by_line = {}
        for idx, line in enumerate(wrapped):
            text = _strip_ansi(line)
            for m in pattern.finditer(text):
                if m.start() == m.end():
                    continue
                gi = len(matches)
                matches.append((idx, m.start(), m.end()))
                by_line.setdefault(idx, []).append((m.start(), m.end(), gi))
        return matches, by_line

    def clear_search():
        nonlocal search_pattern, all_matches, matches_by_line, match_pos
        search_pattern = None
        all_matches = []
        matches_by_line = {}
        match_pos = -1

    def jump_to(pos):
        nonlocal top, match_pos
        match_pos = pos % len(all_matches)
        line_idx = all_matches[match_pos][0]
        if line_idx < top or line_idx >= top + content_h:
            top = line_idx

    def render_rows(status_text, status_reverse):
        rows = []
        for y in range(content_h):
            idx = top + y
            line = wrapped[idx] if idx < total else ""
            line_matches = matches_by_line.get(idx)
            if line_matches:
                spans = [(s, e, gi == match_pos) for s, e, gi in line_matches]
                line = _highlight_line(line, spans)
            rows.append(_ljust_visible(line, width) + '\033[0m\033[K')
        if status_reverse:
            rows.append(f'\033[7m{_ljust_visible(status_text, width)}\033[0m\033[K')
        else:
            rows.append(_ljust_visible(status_text, width) + '\033[0m\033[K')
        return rows

    def draw(message=None):
        nonlocal top
        top = max(0, min(top, max(0, total - content_h)))
        if message is not None:
            status, reverse = message, False
        else:
            pct = min(100, int(100 * (top + content_h) / total)) if total > 0 else 100
            if search_pattern is None:
                suffix = ''
            elif all_matches:
                suffix = f"  [match {match_pos+1}/{len(all_matches)}]"
            else:
                suffix = "  [no matches]"
            status, reverse = f" {title}  {top+1}-{min(top+content_h, total)}/{total}  {pct}%{suffix} ", True
        sys.stdout.write('\033[H')
        sys.stdout.write('\n'.join(render_rows(status, reverse)))
        sys.stdout.flush()

    def prompt(prefix):
        buf = ''
        while True:
            sys.stdout.write('\033[H')
            sys.stdout.write('\n'.join(render_rows(f"{prefix}{buf}", False)))
            sys.stdout.flush()
            raw = read_key(tty_fd)
            if raw in (b'\r', b'\n'):
                return buf
            if raw in (b'\x1b', b'\x03'):
                return None
            if raw in (b'\x7f', b'\x08'):
                buf = buf[:-1]
            elif raw == b'\x15':
                buf = ''
            elif len(raw) == 1 and raw[0] >= 0x20:
                buf += raw.decode('utf-8', errors='ignore')

    def do_search(prefix, direction):
        nonlocal search_pattern, search_dir, all_matches, matches_by_line
        pat = prompt(prefix)
        if not pat:
            return None
        try:
            regex = re.compile(pat, re.IGNORECASE)
        except re.error as e:
            return f" Invalid pattern: {e} "
        search_pattern = regex
        search_dir = direction
        all_matches, matches_by_line = compute_matches(regex)
        if not all_matches:
            return " Pattern not found "
        start_line = top + direction
        if direction == 1:
            candidates = [i for i, (ln, _, _) in enumerate(all_matches) if ln >= start_line]
            pos = candidates[0] if candidates else 0
        else:
            candidates = [i for i, (ln, _, _) in enumerate(all_matches) if ln <= start_line]
            pos = candidates[-1] if candidates else len(all_matches) - 1
        jump_to(pos)
        return None

    def repeat_search(direction):
        if search_pattern is None:
            return " No previous search "
        if not all_matches:
            return " Pattern not found "
        jump_to(match_pos + direction)
        return None

    def handle_resize(sig, frame):
        nonlocal width, height, content_h, wrapped, total, needs_redraw, raw_lines, all_matches, matches_by_line, match_pos
        width, height = get_terminal_size()
        content_h = height - 1
        if regenerate is not None:
            raw_lines = regenerate(width)
        wrapped = make_wrapped(width)
        total = len(wrapped)
        if search_pattern is not None:
            all_matches, matches_by_line = compute_matches(search_pattern)
            match_pos = min(match_pos, len(all_matches) - 1) if all_matches else -1
        needs_redraw = True

    def handle_quit(sig, frame):
        nonlocal running
        running = False

    try:
        tty_mod.setcbreak(tty_fd)
        sys.stdout.write('\033[?1049h\033[2J\033[H\033[?25l')
        sys.stdout.flush()
        signal.signal(signal.SIGWINCH, handle_resize)
        signal.signal(signal.SIGINT, handle_quit)
        signal.signal(signal.SIGTERM, handle_quit)

        sel = selectors.DefaultSelector()
        sel.register(tty_fd, selectors.EVENT_READ, data='key')

        pending_message = None
        while running:
            if needs_redraw:
                draw(pending_message)
                pending_message = None
                needs_redraw = False
            for key, _ in sel.select(timeout=0.1):
                try:
                    raw = read_key(tty_fd)
                    cl = content_h
                    if raw in (b'q', b'Q'):
                        running = False
                    elif raw in (b'k', b'\033[A'):
                        top = max(0, top - 1)
                        needs_redraw = True
                    elif raw in (b'j', b'\033[B'):
                        top = min(max(0, total - cl), top + 1)
                        needs_redraw = True
                    elif raw in (b'u', b'\033[5~'):
                        top = max(0, top - max(1, cl // 2))
                        needs_redraw = True
                    elif raw in (b'd', b'\033[6~'):
                        top = min(max(0, total - cl), top + max(1, cl // 2))
                        needs_redraw = True
                    elif raw == b'b':
                        top = max(0, top - cl)
                        needs_redraw = True
                    elif raw == b'f':
                        top = min(max(0, total - cl), top + cl)
                        needs_redraw = True
                    elif raw == b'G':
                        top = max(0, total - cl)
                        needs_redraw = True
                    elif raw == b'g':
                        top = 0
                        needs_redraw = True
                    elif raw == b'/':
                        pending_message = do_search('/', 1)
                        needs_redraw = True
                    elif raw == b'?':
                        pending_message = do_search('?', -1)
                        needs_redraw = True
                    elif raw == b'n':
                        pending_message = repeat_search(search_dir)
                        needs_redraw = True
                    elif raw == b'N':
                        pending_message = repeat_search(-search_dir)
                        needs_redraw = True
                    elif raw == b'\x1b':
                        clear_search()
                        needs_redraw = True
                except (IOError, OSError):
                    pass
    finally:
        import termios as _t
        _t.tcsetattr(tty_fd, _t.TCSADRAIN, old_termios)
        sys.stdout.write('\033[?1049l\033[?25h')
        sys.stdout.flush()
        if tty_file:
            tty_file.close()

def main():
    args = sys.argv[1:]
    ignore_ws = False
    full_mode = False
    viewer_mode = False
    files = []
    show_help = False

    i = 0
    while i < len(args):
        a = args[i]
        if a in ('-h', '--help'):
            show_help = True
            break
        elif a.startswith('-') and len(a) > 1 and not a.startswith('--'):
            for c in a[1:]:
                if c == 'w':
                    ignore_ws = True
                elif c == 'f':
                    full_mode = True
                elif c == 'v':
                    viewer_mode = True
                elif c == 'h':
                    show_help = True
                else:
                    print(f"zd: unknown option: -{c}", file=sys.stderr)
                    sys.exit(1)
        else:
            files.append(a)
        i += 1

    if show_help:
        print("Usage: zd [-w] [-f] [-v] <file1> <file2>   OR   <cmd> | zd [-w] [-f] [-v]")
        print("  -w  ignore whitespace differences")
        print("  -f  show full files side by side with line numbers (requires two file args)")
        print("  -v  interactive viewer  keybindings: j/k scroll  u/d half-page  b/f full-page  g/G top/bottom")
        print("      / search  ? reverse search  n/N next/previous match  Esc clear search  q quit")
        sys.exit(0)

    if not files:
        if sys.stdin.isatty():
            print("Usage: zd [-w] [-f] [-v] <file1> <file2>   OR   <cmd> | zd [-w] [-f] [-v]")
            sys.exit(1)
        if full_mode:
            print("zd: -f requires two file arguments", file=sys.stderr)
            sys.exit(1)
        if viewer_mode:
            raw_input = list(sys.stdin)
            def _regen(w, _r=raw_input, _iw=ignore_ws):
                b = io.StringIO()
                process_diff(iter(_r), b, ignore_ws=_iw, term_width=w)
                return b.getvalue().splitlines()
            buf = io.StringIO()
            process_diff(iter(raw_input), buf, ignore_ws=ignore_ws)
            run_viewer(buf.getvalue().splitlines(), title="zd", regenerate=_regen)
        else:
            process_diff(sys.stdin, sys.stdout, ignore_ws=ignore_ws)
    elif len(files) == 2:
        if full_mode:
            if viewer_mode:
                def _regen_full(w, _f0=files[0], _f1=files[1], _iw=ignore_ws):
                    b = io.StringIO()
                    generate_full_diff(_f0, _f1, ignore_ws=_iw, out=b, term_width=w)
                    return b.getvalue().splitlines()
                buf = io.StringIO()
                has_diff = generate_full_diff(files[0], files[1], ignore_ws=ignore_ws, out=buf)
                run_viewer(buf.getvalue().splitlines(),
                           title=f"{os.path.basename(files[0])} <-> {os.path.basename(files[1])}",
                           regenerate=_regen_full)
                sys.exit(1 if has_diff else 0)
            else:
                has_diff = generate_full_diff(files[0], files[1], ignore_ws=ignore_ws)
                sys.exit(1 if has_diff else 0)
        else:
            diff_flags = ['-u']
            if ignore_ws:
                diff_flags.append('-w')
            cmd = ['diff'] + diff_flags + files
            p = subprocess.Popen(cmd, stdout=subprocess.PIPE, universal_newlines=True)
            if viewer_mode:
                raw_diff = list(p.stdout)
                p.wait()
                rc = p.returncode
                def _regen_diff(w, _r=raw_diff, _iw=ignore_ws):
                    b = io.StringIO()
                    process_diff(iter(_r), b, ignore_ws=_iw, term_width=w)
                    return b.getvalue().splitlines()
                buf = io.StringIO()
                process_diff(iter(raw_diff), buf, ignore_ws=ignore_ws)
                run_viewer(buf.getvalue().splitlines(),
                           title=f"{os.path.basename(files[0])} <-> {os.path.basename(files[1])}",
                           regenerate=_regen_diff)
                sys.exit(rc)
            else:
                process_diff(p.stdout, sys.stdout, ignore_ws=ignore_ws)
                p.wait()
                sys.exit(p.returncode)
    else:
        print("Usage: zd [-w] [-f] [-v] <file1> <file2>   OR   <cmd> | zd [-w] [-f] [-v]")
        sys.exit(1)

if __name__ == "__main__":
    main()
