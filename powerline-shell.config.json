{
  "segments": [
    "virtual_env",
    "ssh",
    "username",
    {
      "type": "stdout",
      "command": ["pwd"],
      "fg_color": 0,
      "bg_color": 4
    },
    "git",
    "newline",
    {
      "type": "stdout",
      "command": ["sh", "-c", "basename \"$PWD\""],
      "fg_color": 0,
      "bg_color": 2
    },
    "root"
  ],
  "mode": "patched",
  "theme": "basic"
}
