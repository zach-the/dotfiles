set tcl_prompt1 {
    set host [info hostname]
    set dir [file tail [pwd]]
    
    # Fallback for the root directory (file tail of "/" is empty)
    if {$dir eq ""} {set dir "/"}
    
    puts -nonewline "\[$::env(USER)@${host}\] ${dir} % "
}


set sh_enable_page_mode false
#set svr_keep_unconnected_nets true
set report_default_significant_digits 3
#set sh_enable_line_editing true

# For some reason, we believe when using Redhat 4 (or later?), the following
# sequence must be followed to set vi mode:
#set sh_line_editing_mode emacs
#set sh_line_editing_mode vi
#set sh_line_editing_mode emacs
#set sh_line_editing_mode vi


#############
# Shortcuts #
#############

# Procedure to remove an element from a list
proc lremove {listVariable value} {
    upvar 1 $listVariable var
    set idx [lsearch -exact $var $value]
    set var [lreplace $var $idx $idx]
}

# report_timing
proc rt {args} {
  if {[llength $args] == 2} {
    ### See if it is a potential -to -from combination.
    if {[lsearch $args "-*"] == -1} {
      set args "-from [lindex $args 0] -to [lindex $args 1]"
    }
  }
  eval report_timing -crosstalk_delta -path full_clock_expanded -input_pins -nets -cap -trans -include_hierarchical_pin -nosplit $args
}


# report_timing -delay min
proc rtm {args} {
  if {[llength $args] == 2} {
    ### See if it is a potential -from/-to combination.
    if {[lsearch $args "-*"] == -1} {
      set args "-from [lindex $args 0] -to [lindex $args 1]"
    }
  }
  eval report_timing -delay min -crosstalk_delta -path full_clock_expanded -input_pins -nets -cap -trans -include_hierarchical_pin -nosplit $args
}


# report_cell
proc rc {cell}  {
  return [report_cell -con -ver $cell]
}


# report_net
proc rn {net}  {
  return [report_net -con -ver $net]
}

# report_net on the net connected to $pin
proc rnp {pin}  {
  return [report_net -con -ver [get_net -of_object [get_pins $pin]]]
}


# sizeof_collection
proc sc {col} {
  return [sizeof_collection $col]
}

# report_delay_calc, max values
proc rdc {from_pin to_pin} {
  return [report_delay_calculation -max -from $from_pin -to $to_pin]
}

# report_delay_calc, min values
proc rdcm {from_pin to_pin} {
  return [report_delay_calculation -min -from $from_pin -to $to_pin]
}

# report_delay_calc, max values with crosstalk
proc rdcc {from_pin to_pin} {
  return [report_delay_calculation -max -crosstalk -from $from_pin -to $to_pin]
}

# report_delay_calc, min values with crosstalk
proc rdcmc {from_pin to_pin} {
  return [report_delay_calculation -min -crosstalk -from $from_pin -to $to_pin]
}


# Get cells based on their ref name.  Supports string matching.
proc gcr {ref_name}  {
  return [get_cell -hier -filter "ref_name =~ $ref_name" *]
}

