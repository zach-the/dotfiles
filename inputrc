 # --- Global Readline Settings ---
set editing-mode vi
set show-mode-in-prompt on
set show-all-if-ambiguous on
set menu-complete-display-prefix on
set completion-ignore-case on

# --- Vi Insert Mode Keymaps ---
set keymap vi-insert
TAB: menu-complete
"\e[Z": menu-complete-backward
"\C-w": unix-word-rubout

# --- Vi Command Mode Keymaps ---
set keymap vi-command
"\177": backward-delete-char
"\C-h": backward-delete-char

# --- Environment-Specific Prompts ---
$if Bash
    # Bash: Colorized bracket indicators with cursor shape changes
    # Green [I] + Bar cursor
    set vi-ins-mode-string "\1\e[6 q\e[32m\2[I]\1\e[0m\2 "
    # Blue [N] + Block cursor
    set vi-cmd-mode-string "\1\e[2 q\e[36m\2[N]\1\e[0m\2 "
$else
    # Everything else (Python, PrimeTime, etc.): Simple, colorless brackets
    set vi-ins-mode-string "\1\e[6 q\2[I] "
    set vi-cmd-mode-string "\1\e[2 q\2[N] "
$endif
